# Copie para .env local ou configure no painel da Vercel (Settings > Environment Variables)

# Obrigatório em produção
SECRET_KEY=altere-para-uma-chave-segura-e-aleatoria

# Neon (Vercel): use a connection string POOLED (-pooler) com sslmode=require
# Ex.: postgresql://user:senha@ep-xxx-pooler.sa-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://usuario:senha@host:5432/sigein?sslmode=require

# Opcional: criar tabelas automaticamente no primeiro deploy (use com cuidado)
# RUN_DB_MIGRATIONS=1
